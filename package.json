{
  "name": "context-doctor",
  "version": "0.1.0",
  "private": true,
  "description": "CLI, library, and VS Code extension for analyzing and optimizing LLM context windows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egarrr0808/context-doctor.git"
  },
  "homepage": "https://github.com/egarrr0808/context-doctor#readme",
  "bugs": {
    "url": "https://github.com/egarrr0808/context-doctor/issues"
  },
  "keywords": [
    "llm",
    "tokens",
    "context-window",
    "prompt",
    "optimization",
    "ai",
    "claude",
    "gpt",
    "cursor",
    "openai"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.13.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "pack:vscode": "npm --workspace packages/vscode run package",
    "demo": "vhs demo.tape",
    "install:local": "bash scripts/install.sh --local",
    "install:vscode": "bash scripts/install.sh --local --vscode"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "sharp": "^0.34.5",
    "@vscode/vsce": "^3.9.1",
    "turbo": "^2.5.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.3"
  }
}
